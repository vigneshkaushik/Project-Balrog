# Provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# Model id (provider-specific). Default below is a recent Claude Sonnet id — adjust to what your account supports.
MODEL_NAME=claude-sonnet-4-20250514

# API keys (set the one matching LLM_PROVIDER)
ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-...

# Ollama (when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Agent behavior
SYSTEM_PROMPT=
TEMPERATURE=0.7
MAX_TOKENS=4096
MAX_AGENT_ITERATIONS=20

# Comma-separated tool ids (see app/agent.py registry). Example: echo
TOOLS_ENABLED=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173
