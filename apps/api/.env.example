# =============================================================================
# LLM provider — pick one block below and uncomment it.
# Optional: apps/api/data/agent_user_config.json (from the UI) is applied only
# when its provider matches LLM_PROVIDER here (so .env wins after you change
# provider without clearing the old file).
# =============================================================================

# --- Anthropic ---
LLM_PROVIDER=anthropic
MODEL_NAME=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_BASE_URL=                       # optional: custom Anthropic-compatible endpoint

# --- OpenAI ---
# LLM_PROVIDER=openai
# MODEL_NAME=gpt-4o
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=                          # optional: OpenAI-compatible server (e.g. http://host:port/v1)
# OPENAI_CONTEXT_WINDOW=32768              # required when OPENAI_BASE_URL is set with non-standard model ids

# --- Ollama (native client) ---
# LLM_PROVIDER=ollama
# MODEL_NAME=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=                             # optional: overrides MODEL_NAME for the Ollama tag
# OLLAMA_CONTEXT_WINDOW=32768

# --- Ollama via OpenAI-compatible endpoint ---
# Same as above but routes through the /v1 API instead of the native Ollama client.
# Set OPENAI_BASE_URL to activate; OLLAMA_BASE_URL is then unused for the LLM.
# LLM_PROVIDER=ollama
# MODEL_NAME=llama3.2
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_CONTEXT_WINDOW=32768
# OPENAI_API_KEY=ollama                     # placeholder — most Ollama servers ignore auth

# --- Google Gemini ---
# LLM_PROVIDER=google
# MODEL_NAME=gemini-2.0-flash
# GOOGLE_API_KEY=...

# =============================================================================
# Shared options (all providers)
# =============================================================================
SYSTEM_PROMPT=
TEMPERATURE=0.7
MAX_TOKENS=4096
MAX_AGENT_ITERATIONS=20

# CORS (comma-separated origins allowed by the browser)
CORS_ORIGINS=http://localhost:5173

# Path for persisted agent UI config. Default: apps/api/data/agent_user_config.json
# AGENT_USER_CONFIG_PATH=
