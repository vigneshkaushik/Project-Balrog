# =============================================================================
# LLM provider: pick one of anthropic | openai | ollama | google
# =============================================================================
LLM_PROVIDER=anthropic

# -----------------------------------------------------------------------------
# Anthropic (when LLM_PROVIDER=anthropic)
# -----------------------------------------------------------------------------
MODEL_NAME=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=sk-ant-api03-...
# Optional Anthropic-compatible base URL override.
# ANTHROPIC_BASE_URL=

# -----------------------------------------------------------------------------
# OpenAI (when LLM_PROVIDER=openai)
# Uncomment and set MODEL_NAME + key. Use OPENAI_BASE_URL for OpenAI-compatible servers.
# -----------------------------------------------------------------------------
# LLM_PROVIDER=openai
# MODEL_NAME=gpt-4o
# OPENAI_API_KEY=sk-...
# Example for OpenAI-compatible self-hosted servers:
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_CONTEXT_WINDOW=32768
# Some compatible servers ignore auth; if required by the client, any non-empty placeholder may work:
# OPENAI_API_KEY=dummy

# -----------------------------------------------------------------------------
# Ollama (when LLM_PROVIDER=ollama)
# OLLAMA_* vars are ignored for Anthropic/OpenAI. Use a model tag (e.g. llama3.2).
# -----------------------------------------------------------------------------
# LLM_PROVIDER=ollama
# MODEL_NAME=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=
# OLLAMA_CONTEXT_WINDOW=32768

# -----------------------------------------------------------------------------
# Google Gemini (when LLM_PROVIDER=google)
# -----------------------------------------------------------------------------
# LLM_PROVIDER=google
# MODEL_NAME=gemini-2.0-flash
# GOOGLE_API_KEY=...

# =============================================================================
# Shared agent options (all providers)
# =============================================================================
SYSTEM_PROMPT=
TEMPERATURE=0.7
# Max completion tokens for Anthropic/OpenAI; separate from OLLAMA_CONTEXT_WINDOW.
MAX_TOKENS=4096
MAX_AGENT_ITERATIONS=20

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Optional path for persisted agent UI config (provider, model, API key). Default: apps/api/data/agent_user_config.json
# AGENT_USER_CONFIG_PATH=
